# Copy this file to `.env` before running the server.
# MiniMax is OpenAI-compatible. Get a key from https://platform.minimax.io/
MINIMAX_API_KEY=your_key_here

# Optional overrides (defaults shown)
# MINIMAX_BASE_URL=https://api.minimax.io/v1
# MINIMAX_MODEL=MiniMax-M3
# MINIMAX_FAST_MODEL=MiniMax-M2.5-highspeed

# Optional: override the port (defaults to 3001)
# PORT=3001

# Demo mode (rate limiting) is auto-detected per-request: localhost requests
# run unrestricted, requests to any real domain (Railway, tunnels, etc.) are
# rate-limited. No env var needed.
