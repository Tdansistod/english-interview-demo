# Copy this file to `.env` before running the server.
# The app talks to any OpenAI-compatible endpoint. Use whichever provider you like:
#   MiniMax  — https://platform.minimax.io/  (default base URL below)
#   OpenAI   — https://platform.openai.com/  (set OPENAI_BASE_URL=https://api.openai.com/v1)
#   Groq     — https://console.groq.com/     (set OPENAI_BASE_URL=https://api.groq.com/openai/v1)
OPENAI_API_KEY=your_key_here

# Optional overrides (defaults shown)
# OPENAI_BASE_URL=https://api.minimax.io/v1
# OPENAI_MODEL=MiniMax-M3
# OPENAI_FAST_MODEL=MiniMax-M2.5-highspeed

# Optional: override the port (defaults to 3001)
# PORT=3001

# Demo mode (rate limiting) is auto-detected per-request: localhost requests
# run unrestricted, requests to any real domain (Railway, tunnels, etc.) are
# rate-limited. No env var needed.
